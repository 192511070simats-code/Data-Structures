#include <stdio.h>

struct node
{
    int data;
    struct node *left, *right;
};

void preorder(struct node *root)
{
    if(root)
    {
        printf("%d ", root->data);
        preorder(root->left);
        preorder(root->right);
    }
}

void inorder(struct node *root)
{
    if(root)
    {
        inorder(root->left);
        printf("%d ", root->data);
        inorder(root->right);
    }
}

void postorder(struct node *root)
{
    if(root)
    {
        postorder(root->left);
        postorder(root->right);
        printf("%d ", root->data);
    }
}

int main()
{
    struct node n1 = {1, NULL, NULL};
    struct node n2 = {2, NULL, NULL};
    struct node n3 = {3, NULL, NULL};

    n1.left = &n2;
    n1.right = &n3;

    printf("Preorder: ");
    preorder(&n1);

    printf("\nInorder: ");
    inorder(&n1);

    printf("\nPostorder: ");
    postorder(&n1);

    return 0;
}
