#include <stdio.h>
#include <ctype.h>

char stack[20];
int top = -1;

void push(char x)
{
    stack[++top] = x;
}

char pop()
{
    return stack[top--];
}

int main()
{
    char exp[20];
    int i;

    printf("Enter Infix Expression: ");
    scanf("%s", exp);

    printf("Postfix Expression: ");

    for(i = 0; exp[i] != '\0'; i++)
    {
        if(isalnum(exp[i]))
            printf("%c", exp[i]);
        else
            push(exp[i]);
    }

    while(top != -1)
        printf("%c", pop());

    return 0;
}
